{
	"info": {
		"_postman_id": "pz4-metrics",
		"name": "PZ4 — Prometheus Metrics",
		"description": "Коллекция для генерации нагрузки и проверки метрик.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "host",
			"value": "109.206.243.170",
			"description": "IP сервера"
		},
		{
			"key": "tasks_port",
			"value": "8082"
		}
	],
	"item": [
		{
			"name": "1. Успешные запросы",
			"item": [
				{
					"name": "GET Tasks (success)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer demo-token"
							}
						],
						"url": {
							"raw": "http://{{host}}:{{tasks_port}}/v1/tasks",
							"protocol": "http",
							"host": ["{{host}}"],
							"port": "{{tasks_port}}",
							"path": ["v1", "tasks"]
						}
					},
					"response": []
				},
				{
					"name": "POST Create Task (success)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer demo-token"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Metrics test\",\n  \"description\": \"Load generation\",\n  \"due_date\": \"2026-12-31\"\n}"
						},
						"url": {
							"raw": "http://{{host}}:{{tasks_port}}/v1/tasks",
							"protocol": "http",
							"host": ["{{host}}"],
							"port": "{{tasks_port}}",
							"path": ["v1", "tasks"]
						}
					},
					"response": []
				}
			],
			"description": "Отправьте каждый запрос 10-15 раз для генерации успешной нагрузки."
		},
		{
			"name": "2. Ошибочные запросы (401)",
			"item": [
				{
					"name": "GET Tasks (invalid token)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer wrong-token"
							}
						],
						"url": {
							"raw": "http://{{host}}:{{tasks_port}}/v1/tasks",
							"protocol": "http",
							"host": ["{{host}}"],
							"port": "{{tasks_port}}",
							"path": ["v1", "tasks"]
						}
					},
					"response": []
				},
				{
					"name": "GET Tasks (no token)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://{{host}}:{{tasks_port}}/v1/tasks",
							"protocol": "http",
							"host": ["{{host}}"],
							"port": "{{tasks_port}}",
							"path": ["v1", "tasks"]
						}
					},
					"response": []
				}
			],
			"description": "Отправьте каждый запрос 10 раз для генерации ошибок 401."
		},
		{
			"name": "3. Проверка метрик",
			"item": [
				{
					"name": "GET /metrics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://{{host}}:{{tasks_port}}/metrics",
							"protocol": "http",
							"host": ["{{host}}"],
							"port": "{{tasks_port}}",
							"path": ["metrics"]
						}
					},
					"response": []
				}
			],
			"description": "Проверка вывода /metrics. Найдите строки http_requests_total, http_request_duration_seconds, http_in_flight_requests."
		}
	]
}
