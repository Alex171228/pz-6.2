{
	"info": {
		"_postman_id": "pz5-tls-sqli",
		"name": "PZ5 — HTTPS + SQL Injection",
		"description": "Коллекция для проверки HTTPS через NGINX и защиты от SQL-инъекций.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "host",
			"value": "109.206.243.170",
			"description": "IP сервера"
		},
		{
			"key": "port",
			"value": "8443"
		}
	],
	"item": [
		{
			"name": "1. HTTPS — создать задачу",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer demo-token"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"SQL safe\",\n  \"description\": \"parameterized query\",\n  \"due_date\": \"2026-01-15\"\n}"
				},
				"url": {
					"raw": "https://{{host}}:{{port}}/v1/tasks",
					"protocol": "https",
					"host": ["{{host}}"],
					"port": "{{port}}",
					"path": ["v1", "tasks"]
				},
				"description": "Создание задачи через HTTPS (NGINX). Ожидаем 201."
			},
			"response": []
		},
		{
			"name": "2. HTTPS — получить все задачи",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer demo-token"
					}
				],
				"url": {
					"raw": "https://{{host}}:{{port}}/v1/tasks",
					"protocol": "https",
					"host": ["{{host}}"],
					"port": "{{port}}",
					"path": ["v1", "tasks"]
				},
				"description": "Получение всех задач через HTTPS. Проверяем что задача из шага 1 сохранилась в PostgreSQL."
			},
			"response": []
		},
		{
			"name": "3. Поиск — нормальный запрос",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer demo-token"
					}
				],
				"url": {
					"raw": "https://{{host}}:{{port}}/v1/tasks/search?title=SQL safe",
					"protocol": "https",
					"host": ["{{host}}"],
					"port": "{{port}}",
					"path": ["v1", "tasks", "search"],
					"query": [
						{
							"key": "title",
							"value": "SQL safe"
						}
					]
				},
				"description": "Поиск по title. Должен найти задачу созданную в шаге 1."
			},
			"response": []
		},
		{
			"name": "4. SQLi — попытка инъекции",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer demo-token"
					}
				],
				"url": {
					"raw": "https://{{host}}:{{port}}/v1/tasks/search?title=' OR '1'='1",
					"protocol": "https",
					"host": ["{{host}}"],
					"port": "{{port}}",
					"path": ["v1", "tasks", "search"],
					"query": [
						{
							"key": "title",
							"value": "' OR '1'='1"
						}
					]
				},
				"description": "Попытка SQL-инъекции. Должен вернуть ПУСТОЙ массив [] — параметризация защищает от инъекции."
			},
			"response": []
		}
	],
	"protocolProfileBehavior": {}
}
